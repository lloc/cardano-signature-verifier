*.php diff=php
*.crt text
*.key text
*.zip binary
*.mo binary
*.png binary
*.jpg binary
*.eot binary
*.ttf binary
*.woff2 binary
*.woff binary
*.gif binary
*.ico binary
*.mov binary
*.mp4 binary
*.mp3 binary
*.flv binary
*.fla binary
*.swf binary
*.gz binary
*.7z binary

# Package Management
/composer.lock linguist-generated
/.eslintrc.js export-ignore

# Testing
/tests/ export-ignore
/phpunit.xml* export-ignore
/jest.config.js export-ignore
